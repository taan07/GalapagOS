{
  "name": "galapagos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.5",
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "scripts": {
    "preinstall": "bun scripts/verify-bun-version.ts",
    "verify:bun": "bun scripts/verify-bun-version.ts",
    "dev": "bun run verify:bun && concurrently -n daemon,web -c blue,green \"bun run daemon\" \"bun run web\"",
    "daemon": "bun run verify:bun && tsx watch src/daemon/main.ts",
    "web": "bun run verify:bun && next dev --port 3005",
    "build": "bun run verify:bun && next build",
    "typecheck": "bun run verify:bun && tsc --noEmit",
    "test": "bun run typecheck && bun run test:unit",
    "test:unit": "bun run verify:bun && tsc --project tsconfig.node.json && node --test \"dist-node/tests/*.test.js\"",
    "spike:resume": "bun run verify:bun && tsx scripts/spike-resume.ts",
    "smoke:sqlite": "bun run verify:bun && tsx scripts/smoke-sqlite.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "better-sqlite3": "latest",
    "next": "latest",
    "picomatch": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/picomatch": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
